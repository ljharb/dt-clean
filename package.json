{
	"name": "dt-clean",
	"version": "0.0.0",
	"description": "Ensures the only DefinitelyTyped (`@types`) packages you have installed are the ones you need",
	"bin": "./bin.mjs",
	"exports": {
		"./package.json": "./package.json"
	},
	"imports": {
		"#/*": "./*.mjs"
	},
	"scripts": {
		"prepack": "npmignore --auto --commentLines=autogenerated",
		"prepublish": "not-in-publish || npm run prepublishOnly",
		"prepublishOnly": "safe-publish-latest",
		"postlint": "tsc && attw -P",
		"pretest": "npm run lint",
		"test": "npm run tests-only",
		"tests-only": "c8 tape 'test/*.mjs'",
		"tests:live": "LIVE=1 tape 'test/fixtures.mjs'",
		"tests:registry": "tape 'test/live/registry.mjs'",
		"tests:projects": "tape 'test/live/projects.mjs'",
		"lint": "eslint .",
		"posttest": "npx npm@'>= 10.2' audit --production",
		"version": "auto-changelog && git add CHANGELOG.md",
		"postversion": "auto-changelog && git add CHANGELOG.md && git commit --no-edit --amend && git tag -f \"v$(node -e \"console.log(require('./package.json').version)\")\""
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ljharb/dt-clean.git"
	},
	"author": "Jordan Harband <ljharb@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/ljharb/dt-clean/issues"
	},
	"homepage": "https://github.com/ljharb/dt-clean#readme",
	"dependencies": {
		"@definitelytyped/utils": "^0.1.14",
		"es-errors": "^1.3.0",
		"hastypes": "^4.0.4",
		"pargs": "^1.4.2",
		"semver": "^7.8.4"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@ljharb/eslint-config": "^22.2.3",
		"@ljharb/tsconfig": "^0.3.2",
		"@types/node": "^25.9.3",
		"@types/semver": "^7.7.1",
		"auto-changelog": "^2.6.0",
		"c8": "^11.0.0",
		"eslint": "^10.5.0",
		"esmock": "^2.7.6",
		"globals": "^17.6.0",
		"in-publish": "^2.0.1",
		"npm-high-impact": "^1.13.0",
		"npmignore": "^0.3.5",
		"safe-publish-latest": "^2.0.0",
		"tape": "^5.10.2",
		"typescript": "next"
	},
	"engines": {
		"node": "^24.16 || >= 26.3"
	},
	"auto-changelog": {
		"output": "CHANGELOG.md",
		"template": "keepachangelog",
		"unreleased": false,
		"commitLimit": false,
		"backfillLimit": false,
		"hideCredit": true
	},
	"publishConfig": {
		"ignore": [
			".github/workflows",
			".c8rc.json",
			"eslint.config.mjs",
			"test",
			"types"
		]
	}
}
